# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# Supabase keys (dev only, never commit)
supabase_keys.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# NOTE: prisma/migrations is COMMITTED (CI runs `prisma migrate deploy`).
# A prior .gitignore entry excluded it — Sprint B.7 corrected that.

.env.*
*.p12
*.key
*.crt
credentials*.json
service-account*.json
sessions/
logs/
*.log
.claude/worktrees/

# audit artifacts
/docs/audit/
/screenshots/
audit-*.png

# Sprint B — in-session working artifacts, not part of repo history
**/*.bak-*
.claude/reviews/.prompts/_*
.claude/reviews/_*
.claude/reviews/T1-T3-*
.claude/reviews/*.exitok
.claude/reviews/*.exitcode
.claude/reviews/*.pid
.claude/reviews/npm-*
.claude/reviews/prisma-*
.claude/reviews/tsc-*
.claude/reviews/typecheck-*
.claude/reviews/vitest-*
.claude/reviews/git-*
.claude/reviews/project-critic-paths.txt
.claude/reviews/_claude-help.txt
.claude/reviews/branch-protection.json
.claude/reviews/branch-protection.response.json
.claude/reviews/*.bak-*
