    "lucide-react": "^0.553.0",
    "next": "^15.0.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
