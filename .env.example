# Database
DATABASE_URL=postgresql://user:password@localhost:5432/echocity?connection_limit=10&pool_timeout=30

# Supabase (storage)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_USER_PHOTOS_BUCKET=user-photos

# Auth
SESSION_SECRET=generate-a-random-64-char-string-here
NEXTAUTH_SECRET=generate-a-random-64-char-string-here
NEXTAUTH_URL=https://echocity.example.com

# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# YoKassa payments
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=
YOKASSA_WEBHOOK_SECRET=

# Push Notifications (run: npx tsx scripts/generate-vapid-keys.ts)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@echocity.ru

# Telegram Bot
BOT_TOKEN=
