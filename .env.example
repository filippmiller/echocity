# Database
# Tune Prisma v6 pool params for the deployment size. If using PgBouncer for app
# traffic, keep migration commands on a direct PostgreSQL URL.
DATABASE_URL=postgresql://user:password@localhost:5432/echocity?connection_limit=10&pool_timeout=30&connect_timeout=30

# Storage (MinIO / S3-compatible)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=cityecho-photos
MINIO_PUBLIC_BASE_URL=

# Supabase Storage (used for review photo URL validation)
NEXT_PUBLIC_SUPABASE_URL=

# Auth
SESSION_SECRET=generate-a-random-64-char-string-here
NEXTAUTH_SECRET=generate-a-random-64-char-string-here
NEXTAUTH_URL=https://echocity.example.com
NEXT_PUBLIC_APP_URL=https://echocity.example.com

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=ГдеСейчас <no-reply@echocity.example.com>

# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=

# Yandex Maps
YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# YoKassa payments
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=
YOKASSA_WEBHOOK_SECRET=

# Mini app auth
VK_CLIENT_SECRET=
MAX_CLIENT_SECRET=

# Push Notifications (run: npx tsx scripts/generate-vapid-keys.ts)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@echocity.ru

# Telegram Bot
BOT_TOKEN=

# Feature flags (override database values; omit to use DB/default)
# FEATURE_FLAG_ENABLE_BUNDLE_EXPERIMENT=false
# FEATURE_FLAG_ENABLE_MYSTERY_BAGS=false
# FEATURE_FLAG_ENABLE_GROUP_DEALS=false
# FEATURE_FLAG_ENABLE_DEMAND_RESPONSES=false
# FEATURE_FLAG_ENABLE_STORIES=false
# FEATURE_FLAG_ENABLE_CORPORATE_PLANS=false

# Legal / operator identity
LEGAL_NAME=
LEGAL_INN=
LEGAL_OGRN=
LEGAL_ADDRESS=
SUPPORT_EMAIL=
SUPPORT_PHONE=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_BUILD_SHA=
BUILD_SHA=
